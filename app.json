{
  "expo": {
    "name": "Vinaup",
    "slug": "vinaup-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/images/app-icon-vinaup-android.png",
    "scheme": "vinaup-mobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vinaup.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/images/app-icon-vinaup-android.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.vinaup.mobile"
    },
    "web": {
      "output": "static",
      "favicon": "./src/assets/images/logo-vinaup.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./src/assets/images/splash-screen-vinaup.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5cf39b9f-3233-4922-bc1c-16e5e17afb0c"
      }
    },
    "owner": "doanvinhphu"
  }
}
